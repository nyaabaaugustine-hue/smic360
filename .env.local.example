# ─────────────────────────────────────────────────────────────────────────────
# SMIC360 — Environment Variables
# Copy this file to .env.local and fill in your key.
# ─────────────────────────────────────────────────────────────────────────────

# ── PRIMARY: xAI Grok (Recommended) ──────────────────────────────────────────
# Get your key at: https://console.x.ai/
# Models available: grok-3-mini (fast), grok-3 (most capable)
GROK_API_KEY=xai-...

# ── Optional fallbacks (only used if GROK_API_KEY is not set) ────────────────
# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (free tier) — https://console.groq.com/
# GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: .env.local is already in .gitignore — never commit real API keys.
# ─────────────────────────────────────────────────────────────────────────────
